.DS_Store

# local dev runtime state (conversations, logs, skills)
.nimblebrain

# per-worktree isolated workdir created by `bun run dev:worktree`
.nimblebrain-worktree

# environment fixture runtime state — config files are tracked, generated state is not
.environments/*/conversations/
.environments/*/logs/
.environments/*/data/
.environments/*/.telemetry-id
.environments/*/skills/
.environments/*/files/
.environments/*/automations/
.environments/*/core/
.environments/*/users/
.environments/*/workspaces/

# implementation tasks (ephemeral)
.tasks

# Claude Code internal config (developer tooling, not part of OSS repo)
.claude
.environments/collateral-test/

# git worktrees (local dev only — never commit worktree checkouts)
.worktrees/
